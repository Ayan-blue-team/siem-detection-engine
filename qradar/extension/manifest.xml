<?xml version="1.0" encoding="UTF-8"?>
<!--
╔══════════════════════════════════════════════════════════════════╗
║       SOC CUSTOM OFFENSE RULES - QRADAR EXTENSION FORMAT        ║
║       QRadar Version : 7.5.0                                    ║
║       Total Rules    : 10                                       ║
║       Deploy Method  : API → /api/config/extension_management   ║
╚══════════════════════════════════════════════════════════════════╝
-->
<custom_rules>

  <!--═══════════════════════════════════════════════════════════════
      QR-001 | New Local User Account Created
      MITRE  : T1136.001 - Create Account: Local Account
      EventID: 4720 (Windows) / useradd (Linux)
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-001 | New Local User Account Created</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      Yeni lokal user yaradıldıqda tetiklenir.
      Hücumçular persistence üçün yeni user yaradır.
      MITRE: T1136.001 | EventID: 4720
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>User Account Management</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Windows New User EventID 4720</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <!-- devicetype 12 = Microsoft Windows Security Event Log -->
          <parameter name="eventId" operator="EQUALS" value="4720"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>Yeni lokal user yaradıldı - Persistence cəhdi: ${username} on ${sourceip}</offense_description>
        <contributing_credibility>8</contributing_credibility>
        <contributing_severity>7</contributing_severity>
      </response>
      <response>
        <type>EMAIL</type>
        <to>soc@company.com</to>
        <subject>[QRadar HIGH] New User Created: ${username} on ${sourceip}</subject>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-002 | User Added to Privileged Admin Group
      MITRE  : T1098 / T1078.002
      EventID: 4728, 4732, 4756
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-002 | User Added to Privileged Admin Group</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      İstifadəçi Administrators, Domain Admins, Enterprise Admins
      qruplarına əlavə edildikdə tetiklenir.
      MITRE: T1098 / T1078.002 | EventID: 4728, 4732, 4756
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Privilege Escalation</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Admin Group Member Added</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="IN" value="4728,4732,4756"/>
          <parameter name="payload" operator="IMATCHES"
            value="(?i)(administrators|domain admins|enterprise admins|schema admins|account operators|backup operators)"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>USERNAME</offense_type>
        <offense_description>KRİTİK: ${username} privileged admin qrupuna əlavə edildi!</offense_description>
        <contributing_credibility>9</contributing_credibility>
        <contributing_severity>9</contributing_severity>
      </response>
      <response>
        <type>EMAIL</type>
        <to>soc@company.com</to>
        <subject>[QRadar CRITICAL] User Added to Admin Group: ${username}</subject>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-003 | Brute Force - Multiple Failed Logins
      MITRE  : T1110 - Brute Force
      EventID: 4625
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-003 | Brute Force - Multiple Failed Login Attempts</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      5 dəqiqə ərzində eyni IP-dən 10+ uğursuz login cəhdi.
      MITRE: T1110 | EventID: 4625
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Brute Force Detection</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Failed Login Event</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="EQUALS" value="4625"/>
        </parameters>
      </test>
      <test>
        <name>Threshold 10 in 5 minutes</name>
        <type>FLOW_COUNT</type>
        <parameters>
          <parameter name="timewindow" value="300"/>
          <!-- 300 saniyə = 5 dəqiqə -->
          <parameter name="threshold" value="10"/>
          <parameter name="group_by" value="sourceip"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>Brute Force: ${sourceip} → 5 dəq içində 10+ uğursuz login</offense_description>
        <contributing_credibility>9</contributing_credibility>
        <contributing_severity>8</contributing_severity>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-004 | Privileged Account Login Outside Business Hours
      MITRE  : T1078 - Valid Accounts
      EventID: 4624, LogonType 2/10
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-004 | Privileged Account Login Outside Business Hours</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      Admin/servis hesabları 20:00-06:00 arası login etdikdə tetiklenir.
      MITRE: T1078.002 | EventID: 4624
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Anomalous Activity</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Admin Interactive Login</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="EQUALS" value="4624"/>
          <parameter name="username" operator="IMATCHES" value="(?i)(admin|svc_|sa_|service|root|administrator)"/>
          <parameter name="logonType" operator="IN" value="2,10"/>
        </parameters>
      </test>
      <test>
        <name>Outside Business Hours 20:00-06:00</name>
        <type>TIME</type>
        <parameters>
          <parameter name="hour_from" value="20"/>
          <parameter name="hour_to" value="6"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>USERNAME</offense_type>
        <offense_description>Privileged hesab iş saatları xaricində login etdi: ${username} from ${sourceip}</offense_description>
        <contributing_credibility>7</contributing_credibility>
        <contributing_severity>7</contributing_severity>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-005 | Windows Audit Log Cleared
      MITRE  : T1070.001 - Clear Windows Event Logs
      EventID: 1102, 517
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-005 | Windows Security Audit Log Cleared</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      Windows Security event log silindikdə tetiklenir.
      Hücumçular izlərini silmək üçün logları clear edir.
      MITRE: T1070.001 | EventID: 1102, 517
      KRİTİK - Dərhal araşdırılmalıdır!
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Anti-Forensics</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Audit Log Cleared Event</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="IN" value="1102,517"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>KRİTİK: Windows Audit Log silindi - Anti-forensics cəhdi on ${sourceip}!</offense_description>
        <contributing_credibility>10</contributing_credibility>
        <contributing_severity>10</contributing_severity>
      </response>
      <response>
        <type>EMAIL</type>
        <to>soc@company.com</to>
        <subject>[QRadar CRITICAL] AUDIT LOG CLEARED on ${sourceip}</subject>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-006 | Lateral Movement - Pass-the-Hash
      MITRE  : T1550.002
      EventID: 4624, LogonType=3, NTLM
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-006 | Lateral Movement - Pass-the-Hash Detected</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      Eyni mənbədən 10 dəq içində 3+ fərqli hosta NTLM login.
      MITRE: T1550.002 | EventID: 4624, LogonType=3, NTLM auth
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Lateral Movement</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>NTLM Network Login</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="EQUALS" value="4624"/>
          <parameter name="logonType" operator="EQUALS" value="3"/>
          <parameter name="authenticationPackage" operator="EQUALS" value="NTLM"/>
          <parameter name="username" operator="NOT_EQUALS" value="ANONYMOUS LOGON"/>
        </parameters>
      </test>
      <test>
        <name>3+ Distinct Destinations in 10 min</name>
        <type>FLOW_COUNT</type>
        <parameters>
          <parameter name="timewindow" value="600"/>
          <parameter name="threshold" value="3"/>
          <parameter name="group_by" value="sourceip"/>
          <parameter name="count_distinct" value="destinationip"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>Lateral Movement - Pass-the-Hash: ${sourceip} → multiple hosts via NTLM</offense_description>
        <contributing_credibility>8</contributing_credibility>
        <contributing_severity>9</contributing_severity>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-007 | Ransomware - Mass File Encryption
      MITRE  : T1486 - Data Encrypted for Impact
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-007 | Ransomware Indicator - Mass File Encryption</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      2 dəq ərzində 50+ fayl şifrələnmə uzantısı ilə dəyişdirildikdə.
      MITRE: T1486 | Extensions: .locked .encrypted .crypt .wncry
      KRİTİK - HOST DƏRHƏl İZOLYASİYA EDİLMƏLİDİR!
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Ransomware Detection</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Ransomware File Extension</name>
        <negate>false</negate>
        <parameters>
          <parameter name="category" operator="EQUALS" value="File System"/>
          <parameter name="payload" operator="IMATCHES"
            value="(?i)\.(locked|encrypted|crypt|enc|ryk|rbf|pay2me|wncry|zepto|cerber|locky)$"/>
        </parameters>
      </test>
      <test>
        <name>50+ Files in 2 minutes</name>
        <type>FLOW_COUNT</type>
        <parameters>
          <parameter name="timewindow" value="120"/>
          <parameter name="threshold" value="50"/>
          <parameter name="group_by" value="sourceip"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>KRİTİK RANSOMWARE: ${sourceip} → kütləvi fayl şifrələnməsi aşkarlandı!</offense_description>
        <contributing_credibility>9</contributing_credibility>
        <contributing_severity>10</contributing_severity>
      </response>
      <response>
        <type>EMAIL</type>
        <to>soc@company.com</to>
        <subject>[QRadar CRITICAL] RANSOMWARE DETECTED on ${sourceip} - ISOLATE NOW!</subject>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-008 | Suspicious PowerShell Encoded Command
      MITRE  : T1059.001
      EventID: 4688 / Sysmon 1
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-008 | Suspicious PowerShell Encoded Command Execution</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      PowerShell -EncodedCommand, bypass, hidden flags ilə işlədildikdə.
      MITRE: T1059.001 | EventID: 4688
      Araşdırın: Encoded command-i base64 decode edin!
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Malicious Code Execution</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Encoded PowerShell Execution</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="EQUALS" value="4688"/>
          <parameter name="payload" operator="IMATCHES"
            value="(?i)powershell.*(-enc|-encodedcommand|-nop|-noprofile|-bypass|-windowstyle\s+hidden|-exec\s+bypass|-w\s+hidden)"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>Şübhəli PowerShell: ${sourceip} → encoded/obfuscated komanda icra edildi</offense_description>
        <contributing_credibility>8</contributing_credibility>
        <contributing_severity>8</contributing_severity>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-009 | Network Port Scan Detection
      MITRE  : T1046 - Network Service Discovery
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-009 | Network Port Scan Detected from Single Source</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      1 dəqiqə içində tək IP-dən 20+ fərqli porta bağlantı cəhdi.
      MITRE: T1046 - Network Service Discovery
      Araşdırın: Mənbə IP firewall-da bloklanmalıdır?
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Reconnaissance</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Firewall Deny Events</name>
        <negate>false</negate>
        <parameters>
          <parameter name="category" operator="EQUALS" value="Firewall Deny"/>
        </parameters>
      </test>
      <test>
        <name>20+ Distinct Ports in 1 minute</name>
        <type>FLOW_COUNT</type>
        <parameters>
          <parameter name="timewindow" value="60"/>
          <parameter name="threshold" value="20"/>
          <parameter name="group_by" value="sourceip"/>
          <parameter name="count_distinct" value="destinationPort"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>SOURCE_IP</offense_type>
        <offense_description>Port Scan: ${sourceip} → 1 dəq içində 20+ porta reconnaissance cəhdi</offense_description>
        <contributing_credibility>8</contributing_credibility>
        <contributing_severity>7</contributing_severity>
      </response>
    </responses>
  </custom_rule>

  <!--═══════════════════════════════════════════════════════════════
      QR-010 | Service Account Interactive Login
      MITRE  : T1078.003 - Valid Accounts: Local Accounts
      EventID: 4624, LogonType 2/10
      ═══════════════════════════════════════════════════════════════-->
  <custom_rule>
    <name>SOC-QR-010 | Service Account Interactive Login Detected</name>
    <enabled>true</enabled>
    <owner>admin</owner>
    <type>EVENT</type>
    <notes>
      Servis hesabları (svc_*, *service*) interactive login etdikdə.
      Servis hesabları HEÇVAXT interactive login etməməlidir!
      MITRE: T1078.003 | EventID: 4624, LogonType 2/10
      Araşdırın: Servis hesabının parolu oğurlanıb?
    </notes>
    <groups>
      <group>SOC Custom Rules</group>
      <group>Anomalous Activity</group>
    </groups>
    <rule_contexts>
      <rule_context>EV</rule_context>
    </rule_contexts>
    <tests>
      <test>
        <name>Service Account Interactive Login</name>
        <negate>false</negate>
        <parameters>
          <parameter name="devicetype" operator="EQUALS" value="12"/>
          <parameter name="eventId" operator="EQUALS" value="4624"/>
          <parameter name="logonType" operator="IN" value="2,10"/>
          <parameter name="username" operator="IMATCHES"
            value="(?i)(svc_|_svc|service|_sa|sa_|-sa|-svc|srvc_|_srvc)"/>
        </parameters>
      </test>
    </tests>
    <responses>
      <response>
        <type>OFFENSE</type>
        <offense_type>USERNAME</offense_type>
        <offense_description>Servis hesabı interactive login etdi: ${username} from ${sourceip} - Credential Theft şübhəsi!</offense_description>
        <contributing_credibility>9</contributing_credibility>
        <contributing_severity>8</contributing_severity>
      </response>
      <response>
        <type>EMAIL</type>
        <to>soc@company.com</to>
        <subject>[QRadar HIGH] Service Account Interactive Login: ${username}</subject>
      </response>
    </responses>
  </custom_rule>

</custom_rules>
