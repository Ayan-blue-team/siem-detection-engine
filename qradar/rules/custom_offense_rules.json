{
  "name": "SOC-Rule-01: Log Erasure Detection",
  "description": "Windows sistemində logların silinməsi (wevtutil) aşkarlandı.",
  "enabled": true,
  "type": "EVENT",
  "responseLimiter": {
    "limit": 1,
    "period": 300
  },
  "conditions": {
    "type": "and",
    "conditions": [
      {
        "type": "and",
        "condition": {
          "type": "property",
          "property": "payload",
          "operator": "contains",
          "value": "wevtutil"
        }
      }
    ]
  }
}
